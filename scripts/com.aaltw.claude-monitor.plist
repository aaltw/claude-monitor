<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.aaltw.claude-monitor</string>

    <key>ProgramArguments</key>
    <array>
        <!-- Replace with your actual path to the claude-monitor binary -->
        <string>/usr/local/bin/claude-monitor</string>
        <string>web</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/claude-monitor.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/claude-monitor.log</string>
</dict>
</plist>
